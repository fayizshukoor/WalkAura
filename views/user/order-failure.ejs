<main class="flex-grow flex items-center justify-center px-4 py-16 sm:py-24">
  <div class="max-w-md w-full bg-[#101422] border border-white/10 rounded-xl p-6 sm:p-10 text-center shadow-2xl">
    
    <div class="mb-4 inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-500/10 text-red-500">
      <span class="material-symbols-outlined !text-4xl">error</span>
    </div>
    <h1 class="text-3xl font-extrabold mb-8 tracking-tight text-white">Payment Failed</h1>

    <div class="text-left mb-8">
      <h2 class="text-xs uppercase tracking-[0.2em] text-gray-500 font-bold mb-4 flex items-center gap-2">
        <span>📦</span> Order Summary
      </h2>
      
      <div class="bg-black/40 rounded-lg border border-white/5 divide-y divide-white/5">
        <div class="flex justify-between p-4">
          <span class="text-gray-400 text-sm">Order ID</span>
          <span class="text-white font-mono font-medium">#<%= order.orderId || 'N/A' %></span>
        </div>
        
        <div class="flex justify-between p-4">
          <span class="text-gray-400 text-sm">Payment Method</span>
          <span class="text-white font-medium capitalize"><%= order.payment.method || 'UPI / Card' %></span>
        </div>

        <div class="flex justify-between p-4">
          <span class="text-gray-400 text-sm">Amount</span>
          <span class="text-white font-bold">₹<%= order.pricing.totalAmount.toLocaleString() || '0.00' %></span>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-3">
      <button 
        onclick="startRazorpayPayment('<%= order.orderId %>')" 
        class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3.5 px-6 rounded-lg transition-all duration-200 shadow-lg shadow-indigo-500/20"
      >
        Retry Payment
    </button>
      
      <a 
        href="/orders" 
        class="w-full bg-white/5 border border-white/10 hover:bg-white/10 text-gray-300 font-medium py-3 px-6 rounded-lg transition-all"
      >
        Go to Orders
      </a>
    </div>

    <a href="/shop" class="inline-block mt-8 text-xs text-gray-500 hover:text-indigo-400 transition-colors uppercase tracking-widest font-bold">
        Return to Shop
    </a>

  </div>
</main>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>

async function startRazorpayPayment(orderId) {
  try {
      // 1. Show "Restarting" Loading State
      Swal.fire({
          background: '#12141a',
          color: '#fff',
          title: 'Re-initiating Payment',
          text: 'Connecting to secure gateway...',
          allowOutsideClick: false,
          didOpen: () => {
              Swal.showLoading();
          }
      });

      const response = await fetch('/razorpay/create-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ orderId })
      });

      const data = await response.json();

      // If creation fails, we stay on the failure page but show the error
      if (!data.success) {
          Swal.fire({
              background: '#12141a',
              color: '#fff',
              icon: 'error',
              title: 'Order Initialization Failed',
              text: data.message || 'Please try again later.',
              confirmButtonColor: '#4f46e5'
          });
          return;
      }

      const options = {
          key: data.key,
          amount: data.razorpayOrder.amount,
          currency: "INR",
          name: "WalkAura",
          description: "Retry Payment - Order #" + orderId,
          order_id: data.razorpayOrder.id,
          
          handler: async function (response) {
              // 2. Verification Loading State
              Swal.fire({
                  background: '#12141a',
                  color: '#fff',
                  title: 'Verifying Success',
                  text: 'Confirming your payment...',
                  allowOutsideClick: false,
                  didOpen: () => { Swal.showLoading(); }
              });

              const verifyRes = await fetch('/razorpay/verify', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(response)
              });

              const verifyData = await verifyRes.json();

              if (verifyData.success) {
                  window.location.href = `/order-success/${orderId}`;
              } else {
                  // If verification fails, reload the failure page with the orderId
                  window.location.href = `/payment-failed/${orderId}`;
              }
          },

          modal: {
              ondismiss: function () {
                  // Close the loader so they can click 'Retry' again if they closed the modal
                  Swal.close();
              }
          },

          theme: {
              color: "#4f46e5" // Indigo primary
          }
      };

      const rzp = new Razorpay(options);
      rzp.open();
      
      // Hide initialization loader once the Razorpay window is active
      Swal.close();

  } catch (err) {
      console.error("Retry Error:", err);
      Swal.fire({
          background: '#12141a',
          color: '#fff',
          icon: 'error',
          title: 'Connection Error',
          text: 'Could not connect to the payment server.',
          confirmButtonColor: '#4f46e5'
      });
  }
}

</script>