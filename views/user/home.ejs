<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>WalkAura - Premium Footwear</title>
    <link href="https://fonts.googleapis.com" rel="preconnect"/>
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet"/>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#4F46E5",
                        "background-light": "#F3F4F6",
                        "background-dark": "#0B0C10",
                        "surface-light": "#FFFFFF",
                        "surface-dark": "#13151A",
                        "card-dark": "#1F2937",
                    },
                    fontFamily: {
                        display: ["Inter", "sans-serif"],
                        sans: ["Inter", "sans-serif"],
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0) rotate(-15deg)' },
                            '50%': { transform: 'translateY(-20px) rotate(-15deg)' },
                        },
                        fadeIn: {
                            '0%': { opacity: '0', transform: 'translateY(20px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        }
                    }
                },
            },
        };
    </script>
    <style>
        html { scroll-behavior: smooth; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #0B0C10; }
        ::-webkit-scrollbar-thumb { background: #374151; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #4B5563; }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark text-gray-900 dark:text-white font-sans antialiased dark">

<main class="pt-24 pb-20 px-4 max-w-[90%] mx-auto space-y-24">

    <section class="relative overflow-hidden rounded-3xl bg-slate-950 shadow-2xl ring-1 ring-white/10 w-full mb-8">
        <div class="relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-8 items-center p-8 md:p-16 lg:p-24 min-h-[700px]">
            
            <div class="space-y-8 animate-[fadeIn_1s_ease-out_forwards] order-2 lg:order-1 text-center lg:text-left">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-900/30 border border-indigo-500/30 text-indigo-400 text-sm font-medium">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-500 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
                    </span>
                    New Collection
                </div>
                
                <h1 class="text-5xl md:text-7xl font-black tracking-tight leading-[1.1]">
                    <span class="text-indigo-100">Define Your</span> <br/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-indigo-600">Next Step.</span>
                </h1>
                
                <p class="text-lg md:text-xl text-indigo-300/80 max-w-lg mx-auto lg:mx-0 leading-relaxed font-light">
                    Discover the fusion of performance engineering and urban style. Designed for comfort, built for the streets, engineered for you.
                </p>
                
                <div class="flex flex-col sm:flex-row gap-4 pt-4 justify-center lg:justify-start">
                    <a href="/shop" class="px-8 py-4 bg-indigo-600 text-white rounded-xl font-bold text-lg hover:shadow-[0_0_20px_rgba(79,70,229,0.4)] hover:bg-indigo-500 transform hover:-translate-y-0.5 transition-all duration-200 flex items-center justify-center gap-2 group">
                        Shop New Collection
                        <span class="material-icons-outlined text-base group-hover:translate-x-1 transition-transform">arrow_forward</span>
                    </a>
                    <a href="/about" class="px-8 py-4 bg-transparent border border-indigo-500/30 text-indigo-300 rounded-xl font-semibold text-lg hover:bg-indigo-500/10 transition-all duration-200 backdrop-blur-sm text-center">
                        Our Story
                    </a>
                </div>
            </div>
    
            <div class="relative order-1 lg:order-2 flex items-center justify-center h-full min-h-[400px]">
                <div class="relative z-10 w-full aspect-square max-w-md overflow-hidden rounded-2xl shadow-2xl border border-white/5">
                    <img alt="WalkAura Featured Sneaker" 
                         class="w-full h-full object-cover transition-transform duration-1000 ease-out hover:scale-110" 
                         src="https://res.cloudinary.com/dhyoqkjrk/image/upload/v1772087371/display_ujb2co.png"/>
                </div>
            </div>
        </div>
    
        <div class="absolute bottom-6 left-1/2 transform -translate-x-1/2 animate-bounce">
            <span class="material-symbols-outlined text-indigo-500/50 text-3xl">keyboard_arrow_down</span>
        </div>
    </section>

    <section>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">Shop by Category</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <a class="group relative h-80 rounded-2xl overflow-hidden cursor-pointer" href="/shop?category=695f4918518f35a9338de666">
                <div class="absolute inset-0 bg-gray-800">
                    <img alt="Casual" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="https://res.cloudinary.com/dhyoqkjrk/image/upload/v1772088935/casual_mbrypr.png"/>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
                <div class="absolute bottom-6 left-0 right-0 text-center">
                    <span class="text-white font-bold text-xl tracking-wide">Casual</span>
                </div>
            </a>
            <a class="group relative h-80 rounded-2xl overflow-hidden cursor-pointer" href="/shop?category=695fcf9d649263df75ca5c0b">
                <div class="absolute inset-0 bg-gray-800">
                    <img alt="Formal" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="https://res.cloudinary.com/dhyoqkjrk/image/upload/v1772088949/formal_ltycux.png"/>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
                <div class="absolute bottom-6 left-0 right-0 text-center">
                    <span class="text-white font-bold text-xl tracking-wide">Formal</span>
                </div>
            </a>
            <a class="group relative h-80 rounded-2xl overflow-hidden cursor-pointer" href="/shop?category=695fcfee649263df75ca5c10">
                <div class="absolute inset-0 bg-gray-800">
                    <img alt="Sports" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="https://res.cloudinary.com/dhyoqkjrk/image/upload/v1772088963/sports_k7cxje.png"/>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
                <div class="absolute bottom-6 left-0 right-0 text-center">
                    <span class="text-white font-bold text-xl tracking-wide">Sports</span>
                </div>
            </a>
        </div>
    </section>

    <section id="new-arrivals">
      <div class="flex justify-between items-end mb-8">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">New Arrivals</h2>
          <a class="text-sm font-medium text-primary hover:text-indigo-400 transition-colors" href="/shop">View All</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <% if (newArrivals && newArrivals.length > 0) { %>
              <% newArrivals.forEach(product => { %>
                  <div class="group flex flex-col cursor-pointer" onclick="window.location.href='/product/<%= product.slug %>'">
                      <div class="relative aspect-square rounded-2xl overflow-hidden bg-surface-dark mb-4 flex items-center justify-center p-6">
                          <img src="<%= product.thumbnail %>" alt="<%= product.name %>" 
                               class="object-contain w-full h-full drop-shadow-xl transition-transform duration-500 group-hover:scale-105 group-hover:-rotate-3"
                               onerror="this.src='https://via.placeholder.com/400x400?text=No+Image';">
                          
                          <% if (product.price > product.finalPrice) { %>
                              <div class="absolute top-3 left-3 bg-green-500 text-black text-[10px] font-bold px-2 py-1 rounded-md uppercase">
                                <%= Math.round(((product.price - product.finalPrice) / product.price) * 100) %>% OFF
                              </div>
                          <% } %>
                      </div>
                      <div class="space-y-1">
                          <h3 class="text-base font-semibold text-gray-900 dark:text-white truncate">
                              <%= product.name %>
                          </h3>
                          <p class="text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wide">
                              <%= product.category.name %>
                          </p>
                          <div class="flex items-center gap-2 mt-1">
                              <span class="text-sm font-bold text-gray-900 dark:text-gray-200">
                                  ₹<%= product.finalPrice.toLocaleString('en-IN') %>
                              </span>
                              <% if (product.price > product.finalPrice) { %>
                                  <span class="text-xs text-gray-500 line-through">
                                      ₹<%= product.price.toLocaleString('en-IN') %>
                                  </span>
                              <% } %>
                          </div>
                      </div>
                  </div>
              <% }) %>
          <% } else { %>
              <div class="col-span-full py-10 text-center text-gray-500 italic">
                  No new arrivals at the moment.
              </div>
          <% } %>
      </div>
  </section>

    <section>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">Shop For</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <a class="group relative h-[340px] rounded-2xl overflow-hidden cursor-pointer shadow-lg" href="/shop?gender=Men">
                <div class="absolute inset-0 bg-gray-800">
                    <img alt="Men" class="w-full h-full object-cover opacity-80 transition-transform duration-700 group-hover:scale-110" src="https://res.cloudinary.com/dhyoqkjrk/image/upload/v1772089103/men_jxcbrx.png"/>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6 flex justify-between items-end">
                    <div>
                        <span class="block text-white font-bold text-2xl mb-1">Men</span>
                        <span class="block text-gray-300 text-sm">Explore Collection</span>
                    </div>
                    <div class="w-8 h-8 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center group-hover:bg-primary transition-colors">
                        <span class="material-icons-outlined text-white text-sm">arrow_forward</span>
                    </div>
                </div>
            </a>
            <a class="group relative h-[340px] rounded-2xl overflow-hidden cursor-pointer shadow-lg" href="/shop?gender=Women">
                <div class="absolute inset-0 bg-gray-800">
                    <img alt="Women" class="w-full h-full object-cover opacity-80 transition-transform duration-700 group-hover:scale-110" src="https://res.cloudinary.com/dhyoqkjrk/image/upload/v1772089113/women_uchzpe.png"/>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6 flex justify-between items-end">
                    <div>
                        <span class="block text-white font-bold text-2xl mb-1">Women</span>
                        <span class="block text-gray-300 text-sm">Explore Collection</span>
                    </div>
                    <div class="w-8 h-8 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center group-hover:bg-primary transition-colors">
                        <span class="material-icons-outlined text-white text-sm">arrow_forward</span>
                    </div>
                </div>
            </a>
            <a class="group relative h-[340px] rounded-2xl overflow-hidden cursor-pointer shadow-lg" href="/shop?gender=Unisex">
                <div class="absolute inset-0 bg-gray-800">
                    <img alt="Unisex" class="w-full h-full object-cover opacity-80 transition-transform duration-700 group-hover:scale-110" src="https://res.cloudinary.com/dhyoqkjrk/image/upload/v1772089124/unisex_owrc6x.png"/>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6 flex justify-between items-end">
                    <div>
                        <span class="block text-white font-bold text-2xl mb-1">Unisex</span>
                        <span class="block text-gray-300 text-sm">Explore Collection</span>
                    </div>
                    <div class="w-8 h-8 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center group-hover:bg-primary transition-colors">
                        <span class="material-icons-outlined text-white text-sm">arrow_forward</span>
                    </div>
                </div>
            </a>
        </div>
    </section>
</main>

</body>
</html>