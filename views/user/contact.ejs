<section class="relative pt-32 pb-20 overflow-hidden ">
    <div class="container mx-auto px-6 relative z-10 text-center">
      <h1 class="text-4xl md:text-6xl font-extrabold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-500">
        Get In Touch
      </h1>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Have questions about your order, a specific drop, or just want to talk kicks? Our team is here to help you find your aura.
      </p>
    </div>
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-primary/10 rounded-full blur-3xl text-primary"></div>
  </section>
  
  <section class="py-12 container mx-auto px-6 mb-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      
      <div class="space-y-6">
        <div class="p-6 rounded-2xl bg-white/5 border border-white/10 flex items-start gap-4">
          <span class="material-symbols-outlined text-primary p-3 bg-primary/10 rounded-lg">mail</span>
          <div>
            <h3 class="font-bold text-white">Email Us</h3>
            <p class="text-gray-400 text-sm">support@walkaura.com</p>
          </div>
        </div>
  
        <div class="p-6 rounded-2xl bg-white/5 border border-white/10 flex items-start gap-4">
          <span class="material-symbols-outlined text-primary p-3 bg-primary/10 rounded-lg">support_agent</span>
          <div>
            <h3 class="font-bold text-white">Support Hours</h3>
            <p class="text-gray-400 text-sm">Mon - Fri: 9am - 6pm EST</p>
          </div>
        </div>
  
      </div>
  
      <div class="lg:col-span-2 relative">
        <div id="successMessage" class="hidden min-h-[430px] flex flex-col items-center justify-center bg-white/5 border border-white/10 rounded-3xl p-8 text-center transition-all duration-300">
          <span class="material-symbols-outlined text-green-400 text-6xl mb-4">check_circle</span>
          <h2 class="text-3xl font-bold text-white mb-2">Message Submitted!</h2>
          <p class="text-gray-400">Thanks for reaching out. The WalkAura team will get back to you shortly.</p>
          <button onclick="location.reload()" class="mt-6 text-primary hover:underline text-sm font-medium">Send another message</button>
        </div>
      
        <form id="contactForm" class="bg-white/5 border border-white/10 p-8 rounded-3xl space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-medium text-gray-400 mb-2">Full Name</label>
              <input type="text" id="name" required 
                class="w-full bg-background-dark border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-white">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-400 mb-2">Email Address</label>
              <input type="email" id="email" required 
                class="w-full bg-background-dark border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-white">
            </div>
          </div>
      
          <div>
            <label class="block text-sm font-medium text-gray-400 mb-2">Message</label>
            <textarea id="message" rows="5" required 
              class="w-full bg-background-dark border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all text-white"></textarea>
          </div>
      
          <button type="submit" 
            class="w-full bg-primary hover:bg-indigo-600 text-white font-bold py-4 rounded-xl transition-all transform hover:scale-[1.01] active:scale-[0.98]">
            Send Message
          </button>
        </form>
      </div>

    </div>
  </section>

  <script>
    const contactForm = document.getElementById('contactForm');
    const successMessage = document.getElementById('successMessage');
  
    contactForm.addEventListener('submit', function(e) {
      e.preventDefault(); // Prevents the page from reloading or calling an endpoint
      
      // Optional: Basic validation check
      if(contactForm.checkValidity()) {
        contactForm.classList.add('hidden');
        successMessage.classList.remove('hidden');
      }
    });
  </script>