<div class="flex flex-col md:flex-row gap-6 pt-20 min-h-screen">
    
    <%- include("../partials/sidebar") %>

    <main class="flex-1 p-6 md:p-10 lg:px-16 bg-black">
        <div class="max-w-4xl mx-auto">
            <h1 class="text-3xl font-bold mb-8 text-white">Refer & Earn</h1>

            <div class="bg-[#111] border border-gray-800 rounded-3xl p-8 md:p-10 shadow-2xl relative overflow-hidden mb-8">
                <div class="absolute top-0 right-0 w-64 h-64 bg-indigo-900/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>

                <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
                    <div class="max-w-md">
                        <div class="inline-flex items-center gap-2 bg-indigo-500/10 text-indigo-400 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-4">
                            <span class="material-symbols-outlined text-sm">auto_awesome</span>
                            Exclusive Community Perk
                        </div>
                        <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-3">
                            Great things are <br/><span class="text-indigo-500">shared.</span>
                        </h2>
                        <p class="text-gray-400 text-sm leading-relaxed">
                            Introduce your circle to the community. When a friend joins using your code, we’ll credit <b>₹300 to both your wallets</b> as a welcome gift. No strings attached.
                        </p>
                    </div>

                    <div class="w-full md:w-auto">
                        <p class="text-gray-500 text-[10px] uppercase font-bold mb-2 ml-1">Your Referral Asset</p>
                        <div class="bg-black/40 border border-gray-700 rounded-2xl p-2 flex items-center justify-between gap-4 min-w-[280px]">
                            <span id="referralCode" class="pl-4 font-mono text-xl font-bold text-white tracking-widest uppercase">
                                <%= referralCode %>
                            </span>
                            <button onclick="copyReferralCode()" class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-3 rounded-xl font-bold transition-all active:scale-95 shadow-lg shadow-indigo-900/20">
                                <span id="copyIcon" class="material-symbols-outlined text-sm">content_copy</span>
                                <span id="copyText">Copy Code</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-12">
                <div class="bg-[#111] border border-gray-800 p-8 rounded-3xl flex items-center gap-6 hover:border-gray-700 transition-all duration-300">
                    <div class="w-14 h-14 rounded-2xl bg-blue-500/10 text-blue-500 flex items-center justify-center">
                        <span class="material-symbols-outlined text-3xl">diversity_3</span>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-1">Network Size</p>
                        <p class="text-3xl font-bold text-white"><%= totalReferrals || 0 %></p>
                    </div>
                </div>

                <div class="bg-[#111] border border-gray-800 p-8 rounded-3xl flex items-center gap-6 hover:border-gray-700 transition-all duration-300">
                    <div class="w-14 h-14 rounded-2xl bg-green-500/10 text-green-500 flex items-center justify-center">
                        <span class="material-symbols-outlined text-3xl">account_balance_wallet</span>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-1">Total Rewards</p>
                        <p class="text-3xl font-bold text-white">₹<%= (totalEarned || 0).toLocaleString('en-IN') %></p>
                    </div>
                </div>
            </div>

            <div class="relative">
                <h3 class="text-xl font-bold text-white mb-8 flex items-center gap-2">
                    The Roadmap to Earning
                    <div class="h-px flex-1 bg-gray-800 ml-4"></div>
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <div class="group">
                        <div class="w-12 h-12 rounded-2xl bg-gray-900 border border-gray-800 text-gray-400 flex items-center justify-center font-bold mb-5 group-hover:border-indigo-500/50 group-hover:text-white transition-all">01</div>
                        <h4 class="text-white font-bold mb-2">Spread the Word</h4>
                        <p class="text-gray-500 text-sm leading-relaxed">Share your unique invite code with your friends via your favorite social platforms.</p>
                    </div>

                    <div class="group">
                        <div class="w-12 h-12 rounded-2xl bg-gray-900 border border-gray-800 text-gray-400 flex items-center justify-center font-bold mb-5 group-hover:border-indigo-500/50 group-hover:text-white transition-all">02</div>
                        <h4 class="text-white font-bold mb-2">Friend Onboards</h4>
                        <p class="text-gray-500 text-sm leading-relaxed">Your friend joins the community by entering your code during their registration process.</p>
                    </div>

                    <div class="group">
                        <div class="w-12 h-12 rounded-2xl bg-indigo-600/20 border border-indigo-500/40 text-indigo-400 flex items-center justify-center font-bold mb-5 shadow-lg shadow-indigo-500/10">03</div>
                        <h4 class="text-white font-bold mb-2">Collective Bonus</h4>
                        <p class="text-gray-500 text-sm leading-relaxed">Once the signup is verified, a ₹300 bonus is instantly credited to both accounts.</p>
                    </div>
                </div>
            </div>

            <div class="mt-16 text-center border-t border-gray-900 pt-8">
                <p class="text-gray-600 text-xs tracking-wide">
                    Participating in this program means you agree to our Referral Policy. Bonus credits are non-transferable.
                </p>
            </div>
        </div>
    </main>
</div>

<script>
function copyReferralCode() {
    const code = document.getElementById('referralCode').innerText.trim();
    const copyText = document.getElementById('copyText');
    const copyIcon = document.getElementById('copyIcon');

    navigator.clipboard.writeText(code).then(() => {
        copyText.innerText = 'Copied!';
        copyIcon.innerText = 'done_all';
        setTimeout(() => {
            copyText.innerText = 'Copy Code';
            copyIcon.innerText = 'content_copy';
        }, 2000);
    });
}
</script>