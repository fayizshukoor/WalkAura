<div class="min-h-screen flex flex-col md:flex-row bg-black">

  <header class="md:hidden flex items-center justify-between p-4 bg-black border-b border-gray-900 sticky top-0 z-[100] w-full">
    <button id="mobileMenuTrigger" class="text-gray-400 hover:text-white flex items-center justify-center p-2">
      <span class="material-symbols-outlined text-3xl">menu</span>
    </button>
  </header>

  <div id="sidebarOverlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[101] hidden md:hidden"></div>

  <aside id="adminSidebar" class="fixed inset-y-0 left-0 z-[102] w-64 border-r border-gray-900 flex flex-col bg-black transition-transform duration-300 transform -translate-x-full md:translate-x-0 md:sticky md:top-0 md:h-screen flex-shrink-0">
    <div class="p-6 pb-2 flex justify-between items-center">
      <div class="flex items-center justify-start h-20 w-full overflow-hidden">
        <img src="https://res.cloudinary.com/dhyoqkjrk/image/upload/v1772074634/walkAura_new_agdks6.png" alt="WalkAura Logo" class="h-full w-auto object-contain transform scale-90 origin-left">
      </div>
      <button id="closeSidebar" class="md:hidden text-gray-400 p-2">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>

    <nav id="admin-sidebar-nav" class="flex-1 px-4 py-2 space-y-1 overflow-y-auto custom-scrollbar">
      <a href="/admin/dashboard" class="nav-item flex items-center gap-3 p-3 rounded-lg transition-all group text-gray-400 hover:text-white hover:bg-white/[0.03]">
        <span class="material-symbols-outlined">dashboard</span>
        <span class="text-sm font-medium">Dashboard</span>
      </a>
      <a href="/admin/orders" class="nav-item flex items-center gap-3 p-3 rounded-lg transition-all group text-gray-400 hover:text-white hover:bg-white/[0.03]">
        <span class="material-symbols-outlined">description</span>
        <span class="text-sm font-medium">Orders</span>
      </a>
      <a href="/admin/products" class="nav-item flex items-center gap-3 p-3 rounded-lg transition-all group text-gray-400 hover:text-white hover:bg-white/[0.03]">
        <span class="material-symbols-outlined">inventory_2</span>
        <span class="text-sm font-medium">Products</span>
      </a>
      <a href="/admin/customers" class="nav-item flex items-center gap-3 p-3 rounded-lg transition-all group text-gray-400 hover:text-white hover:bg-white/[0.03]">
        <span class="material-symbols-outlined">group</span>
        <span class="text-sm font-medium">Customers</span>
      </a>
      <a href="/admin/sales-report" class="nav-item flex items-center gap-3 p-3 rounded-lg transition-all group text-gray-400 hover:text-white hover:bg-white/[0.03]">
        <span class="material-symbols-outlined">monitoring</span>
        <span class="text-sm font-medium">Sales Report</span>
      </a>
      <a href="/admin/coupons" class="nav-item flex items-center gap-3 p-3 rounded-lg transition-all group text-gray-400 hover:text-white hover:bg-white/[0.03]">
        <span class="material-symbols-outlined">confirmation_number</span>
        <span class="text-sm font-medium">Coupon</span>
      </a>
      <a href="/admin/categories" class="nav-item flex items-center gap-3 p-3 rounded-lg transition-all group text-gray-400 hover:text-white hover:bg-white/[0.03]">
        <span class="material-symbols-outlined">folder</span>
        <span class="text-sm font-medium">Category</span>
      </a>
      <a href="/admin/referrals" class="nav-item flex items-center gap-3 p-3 rounded-lg transition-all group text-gray-400 hover:text-white hover:bg-white/[0.03]">
        <span class="material-symbols-outlined">share</span>
        <span class="text-sm font-medium">Referrals</span>
      </a>
    </nav>

    <div class="p-4 border-t border-gray-900">
      <button id="adminLogoutTrigger" class="flex items-center gap-3 p-3 text-gray-400 hover:text-red-500 hover:bg-red-500/5 rounded-lg transition-all group w-full">
        <span class="material-symbols-outlined group-hover:text-red-500 transition-colors">logout</span>
        <span class="text-sm font-medium group-hover:text-red-500 transition-colors">Logout</span>
      </button>
    </div>
  </aside>

  <main class="flex-1 overflow-y-auto">
    </main>

  <div id="adminLogoutModal" class="fixed inset-0 z-[110] hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4">
    <div class="w-full max-w-sm rounded-3xl bg-[#111] border border-gray-800 shadow-2xl p-8 text-center">
      <div class="w-16 h-16 bg-red-500/10 text-red-500 rounded-full flex items-center justify-center mx-auto mb-4">
        <span class="material-symbols-outlined text-3xl">logout</span>
      </div>
      <h2 class="text-xl font-bold text-white mb-2">Logout Admin?</h2>
      <p class="text-gray-400 mb-8 text-sm">You will need to re-authenticate to access the management panel.</p>
      <div class="flex gap-3">
        <button id="cancelLogout" class="flex-1 px-4 py-3 rounded-xl bg-gray-900 text-white hover:bg-gray-800 transition-all font-bold text-sm">Cancel</button>
        <button id="confirmLogout" class="flex-1 px-4 py-3 rounded-xl bg-red-600 text-white hover:bg-red-500 transition-all font-bold text-sm">Logout</button>
      </div>
    </div>
  </div>
</div>

<script>
  // Elements
  const sidebar = document.getElementById("adminSidebar");
  const overlay = document.getElementById("sidebarOverlay");
  const openMobileMenu = document.getElementById("mobileMenuTrigger");
  const closeMobileMenu = document.getElementById("closeSidebar");
  
  const logoutModal = document.getElementById("adminLogoutModal");
  const logoutTrigger = document.getElementById("adminLogoutTrigger");
  const cancelBtn = document.getElementById("cancelLogout");
  const confirmLogoutBtn = document.getElementById("confirmLogout");

  // --- Sidebar Toggle Logic ---
  const toggleSidebar = () => {
    sidebar.classList.toggle("-translate-x-full");
    overlay.classList.toggle("hidden");
    // Prevent scrolling on body when menu is open
    document.body.classList.toggle("overflow-hidden");
  };

  openMobileMenu.addEventListener("click", toggleSidebar);
  closeMobileMenu.addEventListener("click", toggleSidebar);
  overlay.addEventListener("click", toggleSidebar);

  // --- Logout Logic ---
  logoutTrigger.addEventListener("click", () => {
    logoutModal.classList.remove("hidden");
    logoutModal.classList.add("flex");
  });

  cancelBtn.addEventListener("click", () => {
    logoutModal.classList.add("hidden");
    logoutModal.classList.remove("flex");
  });

  confirmLogoutBtn.addEventListener("click", async () => {
    try {
      const response = await fetch("/admin/logout", {
        method: "POST",
        headers: { "Content-Type": "application/json" }
      });
      if (response.ok) {
        window.location.href = "/admin";
      } else {
        alert("Logout failed.");
      }
    } catch (error) {
      console.error("Logout Error:", error);
    }
  });

  // Close modals on backdrop click
  logoutModal.addEventListener("click", (e) => {
    if (e.target === logoutModal) {
      logoutModal.classList.add("hidden");
      logoutModal.classList.remove("flex");
    }
  });
</script>