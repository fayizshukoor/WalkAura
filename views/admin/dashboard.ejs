<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />

<div class="min-h-screen bg-[#09090b] text-gray-100 p-4 lg:p-8">
    <div class="max-w-7xl mx-auto">
        
        <header class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6 mb-10">
            <div>
                <h1 class="text-4xl font-extrabold tracking-tight text-white">Dashboard</h1>
                <p class="text-gray-400 mt-2">Monitor store growth and order lifecycle metrics.</p>
            </div>

            <form action="/admin/dashboard" method="GET" id="filterForm" class="flex flex-wrap items-end gap-3 bg-[#111113] p-4 rounded-2xl border border-gray-800 shadow-sm">
                <div class="space-y-1">
                    <label class="block text-[10px] uppercase text-gray-500 font-black ml-1">Quick Filter</label>
                    <select name="range" id="rangeSelect" class="bg-[#18181b] border border-gray-700 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none transition-all text-white min-w-[140px]">
                        <option value="today" <%= data.range === 'today' ? 'selected' : '' %>>Today</option>
                        <option value="lastWeek" <%= data.range === 'lastWeek' ? 'selected' : '' %>>Last 7 Days</option>
                        <option value="lastMonth" <%= data.range === 'lastMonth' ? 'selected' : '' %>>Last 30 Days</option>
                        <option value="lastYear" <%= data.range === 'lastYear' ? 'selected' : '' %>>Last Year</option>
                        <option value="custom" <%= data.range === 'custom' ? 'selected' : '' %>>Custom Range</option>
                    </select>
                </div>

                <div id="dateContainer" class="flex gap-3 <%= data.range === 'custom' ? '' : 'hidden' %>">
                    <div class="space-y-1">
                        <label class="block text-[10px] uppercase text-gray-500 font-black ml-1">From</label>
                        <input type="date" name="from" id="fromDate" value="<%= filters.from %>" class="bg-[#18181b] border border-gray-700 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                    </div>
                    <div class="space-y-1">
                        <label class="block text-[10px] uppercase text-gray-500 font-black ml-1">To</label>
                        <input type="date" name="to" id="toDate" value="<%= filters.to %>" class="bg-[#18181b] border border-gray-700 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                    </div>
                </div>

                <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-white px-6 py-2 rounded-lg text-sm font-bold transition-colors h-[38px]">
                    Apply
                </button>
            </form>
        </header>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            <div class="bg-[#111113] border border-gray-800 p-5 rounded-2xl relative overflow-hidden group">
                <div class="absolute top-0 right-0 p-3 transition-opacity">
                    <span class="material-symbols-outlined text-6xl text-emerald-500">payments</span>
                </div>
                <h3 class="text-gray-500 text-xs font-bold uppercase tracking-widest">Net Revenue</h3>
                <div class="flex items-baseline gap-2 mt-2">
                    <span class="text-2xl font-bold text-white">₹<%= (data.stats.netRevenue || 0).toLocaleString() %></span>
                </div>
                <div class="mt-4 flex items-center justify-between text-[11px]">
                    <span class="text-gray-500 uppercase">Gross: ₹<%= (data.stats.grossRevenue || 0).toLocaleString() %></span>
                    <span class="text-emerald-500 font-bold bg-emerald-500/10 px-2 py-0.5 rounded">Live</span>
                </div>
            </div>

            <div class="bg-[#111113] border border-gray-800 p-5 rounded-2xl">
                <h3 class="text-gray-500 text-xs font-bold uppercase tracking-widest">Total Orders</h3>
                <p class="text-2xl font-bold text-white mt-2"><%= data.stats.totalOrders || 0 %></p>
                <p class="text-[11px] text-gray-500 mt-4">Average Order Value: <span class="text-indigo-400">₹<%= Math.round(data.stats.averageOrderValue || 0) %></span></p>
            </div>

            <div class="bg-[#111113] border border-gray-800 p-5 rounded-2xl">
                <h3 class="text-gray-500 text-xs font-bold uppercase tracking-widest">Coupons Applied</h3>
                <p class="text-2xl font-bold text-white mt-2">₹<%= (data.stats.totalCouponDiscount || 0).toLocaleString() %></p>
                <p class="text-[11px] text-amber-500 mt-4 uppercase font-bold italic">Promotional impact</p>
            </div>

            <div class="bg-[#111113] border border-gray-800 p-5 rounded-2xl">
                <h3 class="text-gray-500 text-xs font-bold uppercase tracking-widest">Refund Value</h3>
                <p class="text-2xl font-bold text-white mt-2 text-rose-500">₹<%= (data.stats.totalRefund || 0).toLocaleString() %></p>
                <p class="text-[11px] text-gray-500 mt-4 uppercase"><%= data.stats.returnedCount || 0 %> Items processed</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
            <div class="bg-[#111113]/50 border border-emerald-500/20 p-4 rounded-xl flex items-center gap-4">
                <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-500">
                    <span class="material-symbols-outlined">check_circle</span>
                </div>
                <div>
                    <p class="text-xs text-gray-500 uppercase font-bold">Delivered</p>
                    <p class="text-xl font-bold text-white"><%= data.stats.deliveredCount || 0 %></p>
                </div>
            </div>
            <div class="bg-[#111113]/50 border border-rose-500/20 p-4 rounded-xl flex items-center gap-4">
                <div class="w-10 h-10 rounded-lg bg-rose-500/10 flex items-center justify-center text-rose-500">
                    <span class="material-symbols-outlined">cancel</span>
                </div>
                <div>
                    <p class="text-xs text-gray-500 uppercase font-bold">Cancelled</p>
                    <p class="text-xl font-bold text-white"><%= data.stats.cancelledCount || 0 %></p>
                </div>
            </div>
            <div class="bg-[#111113]/50 border border-orange-500/20 p-4 rounded-xl flex items-center gap-4">
                <div class="w-10 h-10 rounded-lg bg-orange-500/10 flex items-center justify-center text-orange-500">
                    <span class="material-symbols-outlined">keyboard_return</span>
                </div>
                <div>
                    <p class="text-xs text-gray-500 uppercase font-bold">Returned</p>
                    <p class="text-xl font-bold text-white"><%= data.stats.returnedCount || 0 %></p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-10">
            <div class="lg:col-span-2 bg-[#111113] border border-gray-800 rounded-2xl p-6 min-h-[450px] flex flex-col">
                <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-indigo-500">monitoring</span>
                    Revenue Trend
                </h3>
                <div class="relative flex-grow w-full">
                    <canvas id="revenueChart"></canvas>
                    <div id="revenueEmpty" class="hidden absolute inset-0 flex flex-col items-center justify-center text-gray-600 italic">
                        <span class="material-symbols-outlined text-4xl mb-2">query_stats</span>
                        No revenue data for this range
                    </div>
                </div>
            </div>

            <div class="bg-[#111113] border border-gray-800 rounded-2xl p-6 min-h-[450px] flex flex-col">
                <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-amber-500">account_balance_wallet</span>
                    Payment Methods
                </h3>
                <div class="relative flex-grow w-full">
                    <canvas id="paymentChart"></canvas>
                    <div id="paymentEmpty" class="hidden absolute inset-0 flex flex-col items-center justify-center text-gray-600 italic text-center">
                        <span class="material-symbols-outlined text-4xl mb-2">data_info_alert</span>
                        No payment distribution found
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-[#111113] border border-gray-800 rounded-2xl overflow-hidden shadow-2xl">
            <div class="px-6 py-5 border-b border-gray-800 bg-white/[0.02]">
                <h3 class="text-lg font-bold text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-emerald-500">rocket_launch</span>
                    Top 5 Selling Products
                </h3>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-[10px] uppercase tracking-[0.15em] text-gray-500 bg-black/20">
                            <th class="px-6 py-4 font-black">Product Details</th>
                            <th class="px-6 py-4 text-center font-black">Units Sold</th>
                            <th class="px-6 py-4 text-right font-black">Total Revenue</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-800/50">
                        <% if (data.topProducts && data.topProducts.length > 0) { %>
                            <% data.topProducts.forEach(item => { %>
                            <tr class="hover:bg-white/[0.03] transition-all">
                                <td class="px-6 py-4">
                                    <div class="flex flex-col">
                                        <span class="text-sm font-semibold text-white leading-tight"><%= item._id.productName %></span>
                                        <span class="text-[10px] text-indigo-400 mt-1 uppercase font-bold tracking-tighter italic">
                                            Size: <%= item._id.size %> • Color: <%= item._id.color %>
                                        </span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="bg-indigo-500/10 text-indigo-400 px-3 py-1 rounded-full text-xs font-black">
                                        <%= item.totalQuantitySold %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <span class="text-emerald-500 font-mono font-bold">₹<%= item.totalRevenue.toLocaleString() %></span>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="3" class="px-6 py-16 text-center text-gray-600 italic">No sales data found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const filterForm = document.getElementById('filterForm');
        const rangeSelect = document.getElementById('rangeSelect');
        const dateContainer = document.getElementById('dateContainer');
        const fromInput = document.getElementById('fromDate');
        const toInput = document.getElementById('toDate');

        // Helper to format date as YYYY-MM-DD correctly in local time
        const formatDate = (date) => {
            const d = new Date(date);
            let month = '' + (d.getMonth() + 1);
            let day = '' + d.getDate();
            const year = d.getFullYear();
            if (month.length < 2) month = '0' + month;
            if (day.length < 2) day = '0' + day;
            return [year, month, day].join('-');
        };

        const setDatesForRange = (range) => {
            const today = new Date();
            let fromDate = new Date();

            switch (range) {
                case 'today':
                    fromDate = today;
                    break;
                case 'lastWeek':
                    fromDate.setDate(today.getDate() - 7);
                    break;
                case 'lastMonth':
                    fromDate.setMonth(today.getMonth() - 1);
                    break;
                case 'lastYear':
                    fromDate.setFullYear(today.getFullYear() - 1);
                    break;
                default:
                    return;
            }
            fromInput.value = formatDate(fromDate);
            toInput.value = formatDate(today);
        };

        // EVENT: Only triggers when user interacts. 
        // This prevents the page from resetting backend values on reload.
        rangeSelect.addEventListener('change', (e) => {
            if (e.target.value === 'custom') {
                dateContainer.classList.remove('hidden');
            } else {
                dateContainer.classList.add('hidden');
                setDatesForRange(e.target.value);
                filterForm.submit(); 
            }
        });

        // --- 2. Data Preparation ---
        const revenueData = <%- JSON.stringify(data.revenueChart || []) %>;
        const paymentData = <%- JSON.stringify(data.paymentStats || []) %>;

        // --- 3. Revenue Chart ---
        const revCtx = document.getElementById('revenueChart');
        if (revenueData.length > 0) {
            new Chart(revCtx, {
                type: 'line',
                data: {
                    labels: revenueData.map(d => d._id),
                    datasets: [{
                        label: 'Net Revenue',
                        data: revenueData.map(d => d.netRevenue),
                        borderColor: '#6366f1',
                        backgroundColor: 'rgba(99, 102, 241, 0.05)',
                        fill: true,
                        tension: 0.3,
                        borderWidth: 2,
                        pointRadius: 4,
                        pointBackgroundColor: '#6366f1'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { 
                            grid: { color: 'rgba(255,255,255,0.03)' },
                            ticks: { color: '#52525b', font: { size: 10 }, callback: v => '₹' + v.toLocaleString() }
                        },
                        x: { grid: { display: false }, ticks: { color: '#52525b', font: { size: 10 } } }
                    }
                }
            });
        } else {
            document.getElementById('revenueEmpty').classList.remove('hidden');
            revCtx.style.display = 'none';
        }

        // --- 4. Payment Chart with Counts ---
        const payCtx = document.getElementById('paymentChart');
        if (paymentData.length > 0) {
            const total = paymentData.reduce((sum, d) => sum + d.count, 0);

            new Chart(payCtx, {
                type: 'doughnut',
                data: {
                    labels: paymentData.map(d => {
                        const label = d._id.charAt(0).toUpperCase() + d._id.slice(1).toLowerCase();
                        return `${label} (${d.count})`; // Showing count in legend
                    }),
                    datasets: [{
                        data: paymentData.map(d => d.count),
                        backgroundColor: ['#6366f1', '#10b981', '#f59e0b', '#f43f5e'],
                        borderWidth: 0,
                        hoverOffset: 15
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { 
                            position: 'bottom', 
                            labels: { 
                                color: '#a1a1aa', 
                                padding: 20, 
                                font: { size: 12, weight: '600' },
                                usePointStyle: true
                            } 
                        },
                        tooltip: {
                            callbacks: {
                                label: (context) => {
                                    const val = context.raw;
                                    const percent = ((val / total) * 100).toFixed(1);
                                    return ` Orders: ${val} (${percent}%)`;
                                }
                            }
                        }
                    },
                    cutout: '70%'
                }
            });
        } else {
            document.getElementById('paymentEmpty').classList.remove('hidden');
            payCtx.style.display = 'none';
        }
    });
</script>