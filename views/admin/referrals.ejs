<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="pt-10 pb-10 px-4">
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 mb-8 max-w-7xl mx-auto">
        <div>
            <h1 class="text-3xl font-bold text-white tracking-tight">Referral Management</h1>
            <p class="text-gray-500 text-sm mt-1">Monitor and track successful referral signups and rewards.</p>
        </div>

        <div class="flex flex-col md:flex-row gap-3 w-full lg:w-auto">
            <div class="relative flex-1 md:w-80">
                <form action="/admin/referrals" method="GET">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 text-xl">search</span>
                    <input type="text" name="search" placeholder="Search by name or email..." value="<%= search %>"
                        class="w-full bg-[#111] border border-gray-800 rounded-xl py-2.5 pl-10 pr-4 text-sm focus:outline-none focus:border-[#5c56f6] transition-colors text-white" />
                </form>
            </div>
        </div>
    </div>

    <div class="bg-[#111] rounded-2xl border border-gray-800 overflow-hidden max-w-7xl mx-auto shadow-2xl">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="text-gray-500 border-b border-gray-800 bg-white/[0.01]">
                    <tr>
                        <th class="p-5 font-semibold uppercase text-[10px] tracking-wider">Referrer (Sender)</th>
                        <th class="p-5 font-semibold uppercase text-[10px] tracking-wider">Referee (New User)</th>
                        <th class="p-5 font-semibold uppercase text-[10px] tracking-wider text-center">Reward Amount</th>
                        <th class="p-5 font-semibold uppercase text-[10px] tracking-wider text-center">Date</th>
                        <th class="p-5 font-semibold uppercase text-[10px] tracking-wider text-center">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-900">
                    <% if (referrals && referrals.length > 0) { %>
                        <% referrals.forEach(ref => { %>
                        <tr class="hover:bg-white/[0.02] transition-colors group">
                            <td class="p-5">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-lg bg-indigo-500/10 flex items-center justify-center text-indigo-500">
                                        <span class="material-symbols-outlined text-[20px]">share</span>
                                    </div>
                                    <div>
                                        <div class="font-medium text-white text-base"><%= ref.referrer.name %></div>
                                        <div class="text-xs text-gray-500"><%= ref.referrer.email %></div>
                                    </div>
                                </div>
                            </td>
                            <td class="p-5">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-500">
                                        <span class="material-symbols-outlined text-[20px]">person_add</span>
                                    </div>
                                    <div>
                                        <div class="font-medium text-white text-base"><%= ref.referee.name %></div>
                                        <div class="text-xs text-gray-500"><%= ref.referee.email %></div>
                                    </div>
                                </div>
                            </td>
                            <td class="p-5 text-center">
                                <div class="text-green-500 font-bold text-lg">₹<%= ref.amount %></div>
                                <div class="text-[10px] text-gray-500 uppercase tracking-widest font-semibold mt-0.5">Dual Credit</div>
                            </td>
                            <td class="p-5 text-center text-gray-400">
                                <div class="text-white font-medium">
                                    <%= new Date(ref.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                </div>
                                <div class="text-[10px] text-gray-600 uppercase mt-1">
                                    <%= new Date(ref.createdAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                                </div>
                            </td>
                            <td class="p-5 text-center">
                                <span class="inline-flex px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest border 
                                    <%= ref.status === 'Completed' ? 'bg-green-500/10 text-green-500 border-green-500/20' : 'bg-amber-500/10 text-amber-500 border-amber-500/20' %>">
                                    <%= ref.status || 'Success' %>
                                </span>
                            </td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="p-24 text-center">
                                <div class="flex flex-col items-center justify-center">
                                    <div class="w-16 h-16 bg-gray-900 rounded-full flex items-center justify-center mb-4">
                                        <span class="material-symbols-outlined text-gray-700 text-4xl">group_off</span>
                                    </div>
                                    <p class="text-gray-500 italic">No referral transactions found matching your criteria.</p>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <div class="px-6 py-5 bg-white/[0.02] border-t border-gray-800">
            <div class="flex flex-col md:flex-row items-center justify-between gap-5 w-full">
                <div class="text-[10px] uppercase tracking-widest font-bold text-gray-600">
                    Showing Page <%= currentPage %> of <%= totalPages %>
                </div>
                
                <div class="flex items-center gap-2">
                    <% if (currentPage > 1) { %>
                        <a href="/admin/referrals?page=<%= currentPage - 1 %>&search=<%= search %>" 
                           class="px-3 py-1.5 bg-[#1a1a1a] border border-gray-800 rounded-lg text-xs text-gray-400 hover:text-white flex items-center gap-1 transition-colors">
                            <span class="material-symbols-outlined text-sm">chevron_left</span> Prev
                        </a>
                    <% } %>

                    <% 
                    let start = Math.max(1, currentPage - 2);
                    let end = Math.min(totalPages, start + 4);
                    if (end - start < 4) start = Math.max(1, end - 4);
                    for(let i = start; i <= end; i++) { 
                    %>
                        <a href="/admin/referrals?page=<%= i %>&search=<%= search %>" 
                           class="w-8 h-8 flex items-center justify-center rounded-lg text-xs font-bold transition-all <%= currentPage === i ? 'bg-[#5c56f6] text-white shadow-lg shadow-[#5c56f6]/20' : 'bg-[#1a1a1a] border border-gray-800 text-gray-400 hover:border-gray-600' %>">
                            <%= i %>
                        </a>
                    <% } %>

                    <% if (currentPage < totalPages) { %>
                        <a href="/admin/referrals?page=<%= currentPage + 1 %>&search=<%= search %>" 
                           class="px-3 py-1.5 bg-[#1a1a1a] border border-gray-800 rounded-lg text-xs text-gray-400 hover:text-white flex items-center gap-1 transition-colors">
                            Next <span class="material-symbols-outlined text-sm">chevron_right</span>
                        </a>
                    <% } %>
                </div>

                <div class="hidden md:block flex-1"></div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Styling for the search input to match your coupon UI */
    input[name="search"]::placeholder {
        color: #374151;
    }
</style>