<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />

<div class="min-h-screen bg-[#09090b] text-gray-100 p-4 lg:p-8 font-sans selection:bg-indigo-500/30">
    <div class="max-w-7xl mx-auto">
        
        <header class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6 mb-10">
            <div>
                <h1 class="text-4xl font-extrabold tracking-tight text-white flex items-center gap-3">
                    <span class="material-symbols-outlined text-4xl text-indigo-500">analytics</span>
                    Sales Report
                </h1>
                <p class="text-gray-400 mt-2 text-lg">Analyze financial performance and transaction lifecycles.</p>
            </div>

            <div class="flex items-center gap-3">
                <a href="/admin/sales-report/export-pdf?range=<%= filters.range %>&from=<%= filters.from %>&to=<%= filters.to %>" 
                   class="flex items-center gap-2 px-5 py-2.5 bg-rose-600/10 border border-rose-500/20 text-rose-500 rounded-xl font-bold hover:bg-rose-600 hover:text-white transition-all shadow-lg shadow-rose-900/10">
                    <span class="material-symbols-outlined text-xl">picture_as_pdf</span>
                    Export PDF
                </a>
                <a href="/admin/sales-report/export-excel?range=<%= filters.range %>&from=<%= filters.from %>&to=<%= filters.to %>" 
                   class="flex items-center gap-2 px-5 py-2.5 bg-emerald-600/10 border border-emerald-500/20 text-emerald-500 rounded-xl font-bold hover:bg-emerald-600 hover:text-white transition-all shadow-lg shadow-emerald-900/10">
                    <span class="material-symbols-outlined text-xl">description</span>
                    Export Excel
                </a>
            </div>
        </header>

        <div class="bg-[#111113] border border-gray-800 p-6 rounded-3xl shadow-xl mb-8">
            <form action="/admin/sales-report" method="GET" id="filterForm" class="flex flex-wrap items-end gap-6">
                <div class="flex-1 min-w-[200px] space-y-2">
                    <label class="block text-xs uppercase text-gray-500 font-black tracking-widest ml-1">Timeframe</label>
                    <select name="range" id="rangeSelect" class="w-full bg-[#18181b] border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-indigo-500 outline-none transition-all cursor-pointer">
                        <option value="today" <%= filters.range === 'today' ? 'selected' : '' %>>Today</option>
                        <option value="lastWeek" <%= filters.range === 'lastWeek' ? 'selected' : '' %>>Last 7 Days</option>
                        <option value="lastMonth" <%= filters.range === 'lastMonth' ? 'selected' : '' %>>Last 30 Days</option>
                        <option value="lastYear" <%= filters.range === 'lastYear' ? 'selected' : '' %>>Last 1 Year</option>
                        <option value="custom" <%= filters.range === 'custom' ? 'selected' : '' %>>Custom Range</option>
                    </select>
                </div>

                <div id="dateContainer" class="flex flex-wrap gap-4 flex-[2]">
                    <div class="flex-1 min-w-[160px] space-y-2">
                        <label class="block text-xs uppercase text-gray-500 font-black tracking-widest ml-1">From Date</label>
                        <input type="date" name="from" id="fromDate" value="<%= filters.from %>" class="w-full bg-[#18181b] border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-indigo-500 outline-none transition-all [color-scheme:dark]">
                    </div>
                    <div class="flex-1 min-w-[160px] space-y-2">
                        <label class="block text-xs uppercase text-gray-500 font-black tracking-widest ml-1">To Date</label>
                        <input type="date" name="to" id="toDate" value="<%= filters.to %>" class="w-full bg-[#18181b] border border-gray-700 rounded-xl px-4 py-3 text-white focus:ring-2 focus:ring-indigo-500 outline-none transition-all [color-scheme:dark]">
                    </div>
                </div>

                <div class="flex items-center gap-3">
                    <button type="button" id="clearFilters" class="bg-gray-800 hover:bg-gray-700 text-gray-300 px-6 py-3.5 rounded-xl font-bold transition-all flex items-center gap-2 active:scale-95">
                        <span class="material-symbols-outlined">restart_alt</span>
                        Clear
                    </button>
                
                    <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-white px-8 py-3.5 rounded-xl font-bold transition-all flex items-center gap-2 shadow-lg shadow-indigo-600/20 active:scale-95">
                        <span class="material-symbols-outlined">filter_list</span>
                        Apply Filters
                    </button>
                </div>
            </form>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
            <div class="bg-[#111113] border border-gray-800 p-6 rounded-3xl relative overflow-hidden group">
                <div class="absolute -right-4 -top-4 opacity-[0.03] group-hover:opacity-[0.07] transition-opacity">
                    <span class="material-symbols-outlined text-9xl text-white">shopping_bag</span>
                </div>
                <h3 class="text-gray-500 text-sm font-black uppercase tracking-[0.2em]">Total Orders</h3>
                <p class="text-4xl font-extrabold text-white mt-3"><%= (data.summary.totalOrders || 0).toLocaleString() %></p>
                <div class="mt-4 h-1 w-12 bg-indigo-500 rounded-full"></div>
            </div>

            <div class="bg-[#111113] border border-gray-800 p-6 rounded-3xl relative overflow-hidden group">
                <h3 class="text-gray-500 text-sm font-black uppercase tracking-[0.2em]">Gross Revenue</h3>
                <p class="text-4xl font-extrabold text-white mt-3">₹<%= (data.summary.grossRevenue || 0).toLocaleString() %></p>
                <p class="text-xs text-emerald-500 font-bold mt-2 flex items-center gap-1">
                    <span class="material-symbols-outlined text-xs">trending_up</span> Pre-refunds & discounts
                </p>
            </div>

            <div class="bg-[#111113] border border-gray-800 p-6 rounded-3xl relative overflow-hidden group">
                <h3 class="text-gray-500 text-sm font-black uppercase tracking-[0.2em]">Refunds</h3>
                <p class="text-4xl font-extrabold text-rose-500 mt-3">₹<%= (data.summary.totalRefund || 0).toLocaleString() %></p>
                <div class="mt-4 h-1 w-12 bg-rose-500 rounded-full"></div>
            </div>

            <div class="bg-indigo-600 border border-indigo-400 p-6 rounded-3xl relative overflow-hidden shadow-2xl shadow-indigo-600/20 group">
                <div class="absolute -right-2 -bottom-2 opacity-20 transition-transform group-hover:scale-110">
                    <span class="material-symbols-outlined text-8xl text-white">payments</span>
                </div>
                <h3 class="text-indigo-100 text-sm font-black uppercase tracking-[0.2em]">Net Revenue</h3>
                <p class="text-4xl font-extrabold text-white mt-3">₹<%= (data.summary.netRevenue || 0).toLocaleString() %></p>
                <p class="text-xs text-indigo-200 font-bold mt-2 uppercase tracking-tighter">Actual Profit Realized</p>
            </div>
        </div>

        <div class="bg-[#111113] border border-gray-800 rounded-3xl overflow-hidden shadow-2xl">
            <div class="px-8 py-6 border-b border-gray-800 flex justify-between items-center bg-white/[0.01]">
                <h3 class="text-xl font-bold text-white flex items-center gap-3">
                    <span class="material-symbols-outlined text-indigo-400">list_alt</span>
                    Detailed Log
                </h3>
            </div>
            
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="text-[12px] uppercase tracking-[0.15em] text-gray-500 bg-black/20">
                            <th class="px-8 py-5 font-black">Order ID & Date</th>
                            <th class="px-6 py-5 font-black">Method</th>
                            <th class="px-6 py-5 font-black">Status</th>
                            <th class="px-6 py-5 text-right font-black">Gross</th>
                            <th class="px-6 py-5 text-right font-black text-rose-400">Refund</th>
                            <th class="px-6 py-5 text-right font-black text-amber-400">Coupon</th>
                            <th class="px-8 py-5 text-right font-black text-indigo-400">Net Amount</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-800/50">
                        <% if (data.orders && data.orders.length > 0) { %>
                            <% data.orders.forEach(order => { %>
                            <tr class="hover:bg-indigo-500/[0.03] transition-colors group">
                                <td class="px-8 py-6">
                                    <div class="flex flex-col">
                                        <span class="text-base font-bold text-white group-hover:text-indigo-400 transition-colors">#<%= order.orderId %></span>
                                        <span class="text-sm text-gray-500 mt-1 uppercase font-medium">
                                            <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                        </span>
                                    </div>
                                </td>
                                <td class="px-6 py-6">
                                    <span class="text-sm font-bold text-gray-300 uppercase tracking-tight"><%= order.payment.method %></span>
                                </td>
                                <td class="px-6 py-6">
                                    <span class="px-3 py-1.5 rounded-lg text-xs font-black uppercase tracking-wider
                                        <%= order.orderStatus === 'DELIVERED' ? 'bg-emerald-500/10 text-emerald-500 border border-emerald-500/20' : 
                                            order.orderStatus === 'CANCELLED' ? 'bg-rose-500/10 text-rose-500 border border-rose-500/20' : 
                                            'bg-amber-500/10 text-amber-500 border border-amber-500/20' %>">
                                        <%= order.orderStatus %>
                                    </span>
                                </td>
                                <td class="px-6 py-6 text-right font-mono text-base text-gray-400">
                                    ₹<%= (order.totalAmount || 0).toLocaleString() %>
                                </td>
                                <td class="px-6 py-6 text-right font-mono text-base text-rose-500/80">
                                    <%= order.refundAmount > 0 ? `₹${order.refundAmount.toLocaleString()}` : '—' %>
                                </td>
                                <td class="px-6 py-6 text-right font-mono text-base text-amber-500/80">
                                    <%= order.couponDiscount > 0 ? `₹${order.couponDiscount.toLocaleString()}` : '—' %>
                                </td>
                                <td class="px-8 py-6 text-right font-mono text-lg font-black text-white">
                                    ₹<%= (order.netAmount || 0).toLocaleString() %>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" class="px-8 py-24 text-center">
                                    <div class="flex flex-col items-center justify-center">
                                        <div class="w-20 h-20 bg-gray-800/50 rounded-full flex items-center justify-center mb-6">
                                            <span class="material-symbols-outlined text-4xl text-gray-600">query_stats</span>
                                        </div>
                                        <h3 class="text-xl font-bold text-white mb-2">No transactions found</h3>
                                        <p class="text-gray-500 max-w-xs mx-auto">Try adjusting your date range or filters to see sales activity.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <% if (data.totalPages > 1) { %>
            <div class="px-8 py-8 border-t border-gray-800 bg-black/40 flex flex-col sm:flex-row items-center justify-between gap-6">
                <div class="text-base text-gray-400 order-2 sm:order-1">
                    Showing <span class="font-bold text-white">Page <%= data.currentPage %></span> of <span class="font-bold text-white"><%= data.totalPages %></span>
                </div>
                
                <div class="flex items-center gap-4 order-1 sm:order-2">
                    <% if (data.currentPage > 1) { %>
                        <a href="?page=<%= data.currentPage - 1 %>&range=<%= filters.range %>&from=<%= filters.from %>&to=<%= filters.to %>" 
                           class="flex items-center gap-2 px-6 py-3 bg-[#18181b] border border-gray-700 rounded-2xl text-base font-bold text-gray-300 hover:bg-gray-800 hover:text-white hover:border-indigo-500 transition-all shadow-xl active:scale-95">
                            <span class="material-symbols-outlined">arrow_back</span>
                            Previous
                        </a>
                    <% } else { %>
                        <button disabled class="flex items-center gap-2 px-6 py-3 bg-[#18181b]/50 border border-gray-800 rounded-2xl text-base font-bold text-gray-600 cursor-not-allowed">
                            <span class="material-symbols-outlined">arrow_back</span>
                            Previous
                        </button>
                    <% } %>

                    <% if (data.currentPage < data.totalPages) { %>
                        <a href="?page=<%= data.currentPage + 1 %>&range=<%= filters.range %>&from=<%= filters.from %>&to=<%= filters.to %>" 
                           class="flex items-center gap-2 px-6 py-3 bg-indigo-600 border border-indigo-500 rounded-2xl text-base font-bold text-white hover:bg-indigo-500 transition-all shadow-xl shadow-indigo-500/20 active:scale-95">
                            Next
                            <span class="material-symbols-outlined">arrow_forward</span>
                        </a>
                    <% } else { %>
                        <button disabled class="flex items-center gap-2 px-6 py-3 bg-[#18181b]/50 border border-gray-800 rounded-2xl text-base font-bold text-gray-600 cursor-not-allowed">
                            Next
                            <span class="material-symbols-outlined">arrow_forward</span>
                        </button>
                    <% } %>
                </div>
            </div>
            <% } %>
        </div>
    </div>
</div>

<script>
   document.addEventListener('DOMContentLoaded', () => {
        const rangeSelect = document.getElementById('rangeSelect');
        const fromInput = document.getElementById('fromDate');
        const toInput = document.getElementById('toDate');
        const filterForm = document.getElementById('filterForm');
        const clearBtn = document.getElementById('clearFilters');

        const formatDate = (date) => {
            const d = new Date(date);
            let month = '' + (d.getMonth() + 1);
            let day = '' + d.getDate();
            const year = d.getFullYear();
            if (month.length < 2) month = '0' + month;
            if (day.length < 2) day = '0' + day;
            return [year, month, day].join('-');
        };

        const todayStr = formatDate(new Date());

        // 2. Set Max Date attribute to prevent future date selection
        fromInput.setAttribute('max', todayStr);
        toInput.setAttribute('max', todayStr);

        // 3. Logic to pre-fill last 7 days if inputs are empty (initial load)
        if (!fromInput.value || !toInput.value) {
        const lastWeek = new Date();
        lastWeek.setDate(lastWeek.getDate() - 7);

        fromInput.value = formatDate(lastWeek);
        toInput.value = todayStr;

        // Match the dropdown to the default pre-filled state
        rangeSelect.value = 'lastWeek';
        }

        // Function to ensure To Date is valid based on From Date
        const validateToDate = () => {
            // Set the minimum selectable 'To Date' to the current 'From Date'
            toInput.min = fromInput.value;

            // If To Date is currently before From Date, reset To Date to match From Date
            if (toInput.value && toInput.value < fromInput.value) {
                toInput.value = fromInput.value;
            }
        };

        const updateDateRange = (range) => {
            const today = new Date();
            let fromDate = new Date();

            switch (range) {
                case 'today':
                    fromDate = today;
                    break;
                case 'lastWeek':
                    fromDate.setDate(today.getDate() - 7);
                    break;
                case 'lastMonth':
                    fromDate.setMonth(today.getMonth() - 1);
                    break;
                case 'lastYear':
                    fromDate.setFullYear(today.getFullYear() - 1);
                    break;
                default:
                    return;
            }
            fromInput.value = formatDate(fromDate);
            toInput.value = formatDate(today);
            validateToDate(); // Ensure constraints update after auto-fill
        };

        clearBtn.addEventListener('click', () => {
            // 1. Reset Select to default (e.g., today)
            rangeSelect.value = 'lastWeek';
            
            // 2. Trigger the date update logic for 'today'
            updateDateRange('lastWeek');
            
            // 3. Submit the form to refresh data
            filterForm.submit();
        });

        // Listen for changes on Range Select
        rangeSelect.addEventListener('change', (e) => {
            if (e.target.value !== 'custom') {
                updateDateRange(e.target.value);
            }
        });

        // Listen for manual changes on From Date
        fromInput.addEventListener('change', () => {
            validateToDate();
            // If user manually changes date, set select to 'custom'
            rangeSelect.value = 'custom';
        });

        toInput.addEventListener('change', () => {
        rangeSelect.value = 'custom';
    });
    
        // Prevent form submission if validation fails (Final check)
        filterForm.addEventListener('submit', (e) => {
            if (toInput.value < fromInput.value) {
                e.preventDefault();
                alert('The "To Date" cannot be earlier than the "From Date".');
            }
        });

        // Initialize min attribute on page load
        validateToDate();
    });
</script>